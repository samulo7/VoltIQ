TZ=Asia/Shanghai

# PostgreSQL
POSTGRES_IMAGE_TAG=16-alpine
POSTGRES_DB=voltiq
POSTGRES_USER=voltiq
POSTGRES_PASSWORD=voltiq_dev_password
